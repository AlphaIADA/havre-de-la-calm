# Core (required for full functionality)
# Example Postgres URL (Neon recommended for production):
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/otaapartments?schema=public

# App / domain (recommended)
NEXT_PUBLIC_ROOT_DOMAIN=otaapartments.local
NEXT_PUBLIC_APP_URL=http://otaapartments.local:3000

# Admin auth (required for /admin login + seed)
ADMIN_EMAIL=admin@otaapartments.local
ADMIN_PASSWORD=change-me-please
ADMIN_SESSION_SECRET=dev-secret-change-me
# Alternative secret name (only used if ADMIN_SESSION_SECRET is not set)
NEXTAUTH_SECRET=

# Uploads (KYC docs) — Cloudinary private assets (required for KYC uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Uploads (public images) — Cloudflare R2 (properties/units/blog)
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
# Public base URL for your bucket (e.g. https://pub-xxxxxxxx.r2.dev or custom domain)
CLOUDFLARE_R2_PUBLIC_URL=
# Optional (defaults to "auto")
CLOUDFLARE_R2_REGION=auto

# Email (optional) — Resend
RESEND_API_KEY=
EMAIL_FROM=OTA Apartments <no-reply@otaapartments.com>
EMAIL_REPLY_TO=

# Payments (optional) — Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=
